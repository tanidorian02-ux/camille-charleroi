graph TD

    subgraph NAVIGATEUR ["NAVIGATEUR (Client)"]
        SR["Web Speech API\nSpeechRecognition\ninterimResults = true"]
        CB["ChatBot.tsx\n──────────────\nhistoryRef  (6 tours)\ncacheRef    (30 entrées)\nspeakResolveRef\ntypeTimerRef"]
        TW["Typewriter\ncalibré sur audio.duration"]
        AUDIO["HTMLAudioElement\nautoplay / barge-in"]
        GHOST["Ghost bubble\n(texte interim)"]
    end

    subgraph NEXTJS ["SERVEUR Next.js (App Router)"]
        CHAT["/api/chat\nroute.ts"]
        SPEAK["/api/speak\nroute.ts"]
        NISS["/api/verifier-niss\nroute.ts"]
        KB["KNOWLEDGE_BASE\n~3 KB injecté\ndans system prompt"]
        HAB["data/habitants.json\nSHA-256 NISS hash\n(RGPD-compliant)"]
        ENV[".env.local\nAPI keys\nVoice IDs\nSite URL"]
    end

    subgraph EXTERNES ["SERVICES EXTERNES"]
        OR["OpenRouter API\ngoogle/gemini-2.5-flash"]
        EL["ElevenLabs TTS\neleven_turbo_v2_5\n~800 ms"]
    end

    SR -->|transcript final| CB
    SR -->|interim text| GHOST
    GHOST --> CB
    CB -->|POST message + history + langue| CHAT
    CB -->|POST text + langue| SPEAK
    CB -->|POST niss / nom| NISS

    CHAT --> KB
    CHAT -->|Prompt + history| OR
    OR -->|reply| CHAT
    CHAT -->|reply JSON| CB

    SPEAK -->|belgiciserNombres fr only| SPEAK
    SPEAK -->|xi-api-key + text + model| EL
    EL -->|audio/mpeg blob| SPEAK
    SPEAK -->|ArrayBuffer| CB

    NISS --> HAB
    NISS -->|statut citoyen| CB

    CB -->|blob URL| AUDIO
    AUDIO -->|canplaythrough → duration| TW
    AUDIO -->|interim barge-in| SR

    ENV -.->|OPENROUTER_API_KEY\nOPENROUTER_MODEL| CHAT
    ENV -.->|ELEVENLABS_API_KEY\nELEVENLABS_VOICE_ID| SPEAK
    ENV -.->|NEXT_PUBLIC_SITE_URL| CHAT

